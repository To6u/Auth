# Скопируй в .env.local и заполни значениями
# Тестовые учётные данные для автозаполнения форм в dev-режиме
VITE_TEST_EMAIL=
VITE_TEST_PASS=

# Demo mode — для деплоя на Cloudflare Pages (нет бэкенда)
# Установить в Cloudflare Pages → Settings → Environment variables
VITE_DEMO_MODE=true
VITE_DEMO_EMAIL=demo@example.com
VITE_DEMO_PASSWORD=demo1234
